---
import "../styles/global.css";

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Borys Gajewski portfolio" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.avif" />
		<link rel="preload" href="/fonts/Alata.woff2" as="font" type="font/woff2" crossorigin />
		<link rel="preload" href="/fonts/AlbertSans.woff2" as="font" type="font/woff2" crossorigin />
		<link rel="preload" href="/fonts/FugazOne.woff2" as="font" type="font/woff2" crossorigin />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>
