			0 0 15px 0 rgba(72, 72, 72, 0.5);
		transition: box-shadow 0.3s;
		&::before {
			position: absolute;
			content: "";
			bottom: -60%;
			left: 20%;
			height: 70%;
			border-radius: 100%;
			width: 60%;
			background-color: rgba(255, 255, 255, 0.4);
			filter: blur(10px);
		}
		&:hover {
			box-shadow:
				inset 0 0 20px 0px rgba(72, 72, 72, 0.8),
				0 0 20px 5px rgba(72, 72, 72, 0.8);
		}
