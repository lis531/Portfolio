		left: 0;
		width: 100%;
		height: 100%;
		/* background-image: url("/images/Background/background.avif"); */
		--pattern-foreground: rgba(255, 255, 255, 0.2);
		--pattern-foreground: color-mix(in oklab, white 20%, transparent);
		background-image: radial-gradient(var(--pattern-foreground) 1px, transparent 1px);
		background-size: 14px 14px;
		background-repeat: repeat;
		background-position: 0 0;
		filter: none;
		z-index: -102;
		@media (max-width: 1200px) {
			filter: none;
			background-position: 0 !important;
		}
	}
	.overlay {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		pointer-events: none;
		background: linear-gradient(
			to right,
			rgba(0, 0, 0, 0.7),
			rgba(0, 0, 0, 0.3) 50%,
			rgba(0, 0, 0, 0.7)
		);
		z-index: -101;
		@media (max-width: 1200px) {
			background: linear-gradient(
				to right,
				rgba(0, 0, 0, 0.7),
				rgba(0, 0, 0, 0) 50%,
				rgba(0, 0, 0, 0.7)
			);
		}
	}
	.light {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		pointer-events: none;
		z-index: -100;
		@media (max-width: 1200px) {
			display: none;
		}
	}
	h1 {
		position: relative;
		display: inline-block;
		width: fit-content;
		margin: 3vh 0;
		line-height: 1;
		padding: 0 0.1em;
		text-align: center;
		background-image: linear-gradient(45deg, #2e99f0, #9b27b0);
		background-clip: text;
		color: transparent;
		&::before {
			content: "";
			position: absolute;
			left: 50%;
			bottom: -0.2em;
			transform: translateX(-50%);
			width: 74%;
			height: 12px;
			background: linear-gradient(90deg, rgba(46, 153, 240, 0.3), rgba(155, 39, 176, 0.3));
			filter: blur(10px);
			border-radius: 999px;
			pointer-events: none;
		}
		&::after {
			content: "";
			position: absolute;
			left: 50%;
			bottom: -0.05em;
			transform: translateX(-50%);
			width: 66%;
			height: 4px;
			background: linear-gradient(90deg, #2e99f0 0%, #8a5dff 50%, #9b27b0 100%);
			border-radius: 999px;
			box-shadow: 0 0 12px rgba(138, 93, 255, 0.7);
			pointer-events: none;
		}
	}
	.blob {
		position: fixed;
		border-radius: 999px;
		filter: blur(44px);
		opacity: 0.35;
		pointer-events: none;
		z-index: -99;
		animation: blobFloat 14s ease-in-out infinite alternate;
	}
	.blob-one {
		top: 12vh;
		right: 5vw;
		width: clamp(180px, 24vw, 400px);
		height: clamp(180px, 24vw, 400px);
		background: radial-gradient(circle at 30% 30%, rgba(46, 153, 240, 0.9), rgba(46, 153, 240, 0));
	}
	.blob-two {
		bottom: 12vh;
		left: 4vw;
		width: clamp(200px, 28vw, 420px);
		height: clamp(200px, 28vw, 420px);
		background: radial-gradient(circle at 65% 35%, rgba(155, 39, 176, 0.9), rgba(155, 39, 176, 0));
		animation-duration: 18s;
	}
	@keyframes blobFloat {
		from {
			transform: translate3d(0, 0, 0) scale(1);
		}
		to {
			transform: translate3d(0, -24px, 0) scale(1.08);
		}
	}
	mark {
		position: relative;
		background-color: transparent;
	}
	mark::after {
		content: "";
		position: absolute;
		top: 0;
		left: 0;
		height: 100%;
		width: 0;
		background-color: yellow;
		z-index: -1;
	}
	mark.animate-mark::after {
		animation: animateMarkBefore 1s 0.5s forwards;
	}
	@keyframes animateMarkBefore {
		from {
			width: 0;
		}
		to {
			width: 100%;
		}
	}
