	.carousel-horizontal {
		height: 50vh;
		display: flex;
		gap: 0.7rem;
		width: max-content;
		align-self: flex-start;
		will-change: transform;
		@media screen and (max-width: 1000px) {
			display: grid;
			grid-template-rows: repeat(2, minmax(0, 1fr));
			grid-auto-columns: min(78vw, 360px);
			gap: 1rem 3rem;
			height: 72vh;
			padding-right: 40vw;
		}
	}
	.carousel-horizontal::-webkit-scrollbar {
		display: none;
	}
	@keyframes spin {
		from {
			translate: 0;
		}
		to {
			translate: -100%;
		}
	}
	.contact {
