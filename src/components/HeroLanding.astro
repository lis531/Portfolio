---
---

<section class="hero" aria-labelledby="hero-title">
	<div class="hero-content">
		<p class="hero-kicker animate">PORTFOLIO</p>
		<h1 id="hero-title" class="animate hero-title">BORYS GAJEWSKI</h1>
		<p class="hero-lead animate">
			I am a <mark>developer</mark> from Poland focused on building websites,
			small games, and practical software.
		</p>
		<div class="hero-actions">
			<a class="animate" href="#projects">See Projects</a>
			<a class="animate" href="#contact">Contact Me</a>
			<a class="animate download" href="/Borys_Gajewski_CV.pdf" target="_blank" rel="noopener" download>
				<svg stroke="currentColor" fill="none" stroke-width="2" viewBox="0 0 24 24" stroke-linecap="round" height="30px" width="30px" xmlns="http://www.w3.org/2000/svg">
					<path d="M4 17v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2 -2v-2"></path><path d="M7 11l5 5l5 -5"></path><path d="M12 4l0 12"></path>
				</svg>
				Download CV
			</a>
		</div>
	</div>
</section>

<style>
	.hero {
		min-height: 100lvh;
		display: flex;
		align-items: center;
		justify-content: center;
		width: min(96vw, 1300px);
		padding: 6rem 0 3rem;
		box-sizing: border-box;
	}

	.hero-title {
		margin: 0 0 3vh 0;
	}

	.hero-content {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1.3rem;
	}

	.hero-kicker {
		font-family: "Alata";
		font-size: clamp(1rem, 1.8vw, 1.4rem);
		letter-spacing: 0.3em;
		margin: 0;
		opacity: 0.8;
	}

	.hero-lead {
		margin: 0;
		max-width: 900px;
		width: 88%;
		font-size: clamp(1.2rem, 2.4vw, 2.2rem);
		line-height: 1.3;
	}

	.hero-actions {
		display: flex;
		gap: 1rem;
		margin-top: 0.7rem;
		flex-wrap: wrap;
		justify-content: center;
	}

	.hero-actions > a {
		text-decoration: none;
		color: white;
		padding: 0.6rem 1.4rem;
		border-radius: 999px;
		border: 1px solid rgba(255, 255, 255, 0.3);
		font-size: clamp(1rem, 1.8vw, 1.4rem);
		transition:
			transform 0.2s ease,
			box-shadow 0.2s ease,
			background-color 0.2s ease;
		background: rgba(255, 255, 255, 0.04);
	}

	.hero-actions > a:hover {
		transform: translateY(-3px);
		box-shadow: 0 8px 20px rgba(0, 0, 0, 0.3);
		background: rgba(255, 255, 255, 0.1);
	}

	.download {
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	@media (max-width: 700px) {
		.hero {
			padding-top: 7.5rem;
			align-items: flex-start;
		}

		.hero-content {
			width: 95%;
		}
	}
</style>
