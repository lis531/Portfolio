---
import Image from 'astro/components/Image.astro';

interface Props {
    title: string;
    description: string;
    date: string;
    href: string;
    hrefTryOut: string;
}

const { title, description, date, href, hrefTryOut } = Astro.props;
const images = import.meta.glob('/public/images/*/*.avif');
const imageUrls = Object.keys(images).map((imagePath) => imagePath.replace('/public', ''));
const filteredImageUrls = imageUrls.filter(url => url.startsWith(`/images/${title.replace(/\s/g, "")}/`));
console.log(filteredImageUrls, title);
---

<div class="carousel-element" id={title.replace(/\s/g, "")}>
    <div class="inset">
        <Image src={filteredImageUrls[0]} alt={title} class={'hidden'} id={`button-img-${title}`} width="600" height="400" />
        <span>
            <p style="color: #ebebeb;">{title}</p>
            <p style="color: rgba(204, 204, 204, 0.75);">{date}</p>
        </span>
    </div>
    <a class="link" href={href} target="_blank">
        View Production <img src="/images/Icons/arrow_link.svg" alt="arrow" width="16px" height="16px" loading="lazy" />
    </a>
</div>
<dialog id={`dialog-${title.replace(/\s/g, "")}`} class="dialog" data-current-index="0">
    <div class="dialog-surface">
        <button class="closeIcon" aria-label="Close dialog" onclick="() => handleDialogClose">X</button>
        <div class="images">
            <button class="prev-button">
                <img src="/images/Icons/arrow_modal.svg" alt="arrow" width="22px" height="22px" loading="lazy" />
            </button>
            {filteredImageUrls.map((url, index) => (
                <img src={url} alt={title + index} loading="lazy" class={index === 0 ? 'fade-in' : 'fade-out'} style={index === 0 ? 'display: block;' : ''} />
            ))}
            <button class="next-button">
                <img src="/images/Icons/arrow_modal.svg" alt="arrow" width="22px" height="22px" loading="lazy" />
            </button>
        </div>

        <div class="dialog-copy">
            <h1>{title}</h1>
            <p>{description}</p>
        </div>
        <div class="dialog-buttons">
            <a class="link" href={href} target="_blank">
                View Production
                <img src="/images/Icons/arrow_link.svg" alt="arrow" width="16px" height="16px" loading="lazy" />
            </a>
            {hrefTryOut !== '' ? <a class="link" href={hrefTryOut} target="_blank">Try out <img src="/images/Icons/arrow_link.svg" alt="arrow" width="16px" height="16px" loading="lazy" /></a> : ''}
        </div>
    </div>
</dialog>

<script>
    const carouselElements = document.querySelectorAll('.carousel-horizontal > .carousel-element');
    carouselElements.forEach(element => {
        element.addEventListener('click', (e) => {
            if(e.target instanceof HTMLAnchorElement) return;

            const target = e.currentTarget as HTMLElement;
            const dialog = document.getElementById(`dialog-${target.id}`) as HTMLDialogElement;
            const images = dialog.querySelectorAll('.images > img') as NodeListOf<HTMLImageElement>;

            images.forEach((img, i) => {
                img.style.display = i === 0 ? 'block' : '';
                img.addEventListener('load', () => {
                    img.classList.add('fade-in');
                });
            });

            dialog.dataset.currentIndex = '0';
            dialog.showModal();
            
            const handleDialogClose = (e: Event) => {
                if (e.target === dialog || e.target === dialog.querySelector('.closeIcon')) {
                    dialog.classList.add('closing');
                    dialog.animate([
                        { transform: 'translate3d(0, 0, 0)', opacity: 1 },
                        { transform: 'translate3d(0, 100%, 0)', opacity: 0 }
                    ], 200).finished.then(() => {
                        dialog.close();
                        dialog.classList.remove('closing');
                    });
                }
            };

            document.body.addEventListener('click', handleDialogClose);

            if (images.length <= 1) return;

            const prevButton = dialog.querySelector('.prev-button') as HTMLButtonElement;
            const nextButton = dialog.querySelector('.next-button') as HTMLButtonElement;

            prevButton.style.display = 'block';
            nextButton.style.display = 'block';

            let isAllowed = true;

            const updateImages = (newIndex: number) => {
                const currentIndex = parseInt(dialog.dataset.currentIndex || '0');
                isAllowed = false;
                images[currentIndex].animate([
                    { opacity: 1 },
                    { opacity: 0 }
                ], 200).finished.then(() => {
                    images[currentIndex].style.display = 'none';
                    images[newIndex].style.display = 'block';
                    images[newIndex].animate([
                        { opacity: 0 },
                        { opacity: 1 }
                    ], 200).finished.then(() => {
                        dialog.dataset.currentIndex = newIndex.toString();
                        isAllowed = true;
                    });
                });
            }

            const handlePrevClick = () => {
                if (!isAllowed) return;
                const currentIndex = parseInt(dialog.dataset.currentIndex || '0');
                const newIndex = (currentIndex > 0) ? currentIndex - 1 : images.length - 1;
                updateImages(newIndex);
            };

            const handleNextClick = () => {
                if (!isAllowed) return;
                const currentIndex = parseInt(dialog.dataset.currentIndex || '0');
                const newIndex = (currentIndex < images.length - 1) ? currentIndex + 1 : 0;
                updateImages(newIndex);
            };

            prevButton.addEventListener('click', handlePrevClick);
            nextButton.addEventListener('click', handleNextClick);
            document.addEventListener('keydown', (e) => {
                if (e.key === 'ArrowLeft') handlePrevClick();
                if (e.key === 'ArrowRight') handleNextClick();
            });
        });
    });
</script>

<style>
    @keyframes transformIn {
        from {
            transform: translate3d(0, 24px, 0) scale(0.97);
            opacity: 0;
        }
        to {
            transform: translate3d(0, 0, 0) scale(1);
            opacity: 1;
        }
    }
    @keyframes backdropAppear {
        from {
            opacity: 0;
            filter: blur(0px);
        }
        to {
            opacity: 1;
            filter: blur(10px);
        }
    }
    @keyframes backdropDisappear {
        from {
            opacity: 1;
            filter: blur(10px);
        }
        to {
            opacity: 0;
            filter: blur(0px);
        }
    }
    .images {
        position: relative;
        width: 100%;
        height: min(44vh, 430px);
        object-fit: cover;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-direction: row;
        margin-top: 0.5rem;
        & > img {
            border-radius: 1.25rem;
            display: none;
            max-width: 100%;
            max-height: 100%;
            height: min(44vh, 430px);
            object-fit: cover;
            border: 1px solid rgba(255, 255, 255, 0.18);
            box-shadow: 0 24px 50px rgba(0, 0, 0, 0.4);
        }
        @media screen and (max-width: 600px) {
            height: 34vh;
            margin-bottom: 0;
            padding: 3.5rem 0 3rem;
            & > img {
                height: 34vh;
            }
        }
    }
    .link {
        font-size: 30px;
        background-color: rgba(28, 28, 28, 0.5);
        border-radius: 1rem;
        color: white;
        text-decoration: none;
        text-align: center;
        width: 100%;
        padding: 0.7rem 0;
        transition: background-color ease-in-out 0.2s;
        &:hover {
            background-color: rgba(28, 28, 28, 0.75);
        }
        & > img {
            margin-left: 0.5rem;
        }
        @media (max-width: 600px) {
            font-size: 20px;
        }
        @media (min-width: 1000px) and (max-width: 1920px) {
            font-size: 22px;
        }
    }
    dialog {
        color: white;
        text-align: center;
        padding: 0;
        margin: 0;
        border: none;
        background: transparent;
        align-content: center;
        width: 100%;
        height: 100%;
        max-width: none;
        max-height: none;
        overflow: hidden;
        & h1 {
            margin: 0.5rem;
            font-size: clamp(2.2rem, 4.6vw, 4.2rem);
            line-height: 0.95;
            letter-spacing: 0.02em;
            @media (max-width: 600px) {
                font-size: 2.3rem;
            }
        }
        & p {
            max-width: 70ch;
            margin: 0;
        }
        & > .dialog-surface {
            margin-inline: auto;
            width: min(88%, 1120px);
            min-height: min(90vh, 860px);
            background:
                radial-gradient(circle at 20% 0%, rgba(63, 188, 255, 0.14), transparent 42%),
                radial-gradient(circle at 80% 100%, rgba(255, 157, 83, 0.17), transparent 45%),
                rgba(10, 13, 17, 0.88);
            border: 1px solid rgba(255, 255, 255, 0.14);
            box-shadow: 0 30px 90px rgba(0, 0, 0, 0.5);
            padding: 1.75rem;
            border-radius: 1.8rem;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: space-between;
            gap: 1.2rem;
            position: relative;
            & > .closeIcon {
                position: absolute;
                top: 0.9rem;
                right: 0.9rem;
                border: 1px solid rgba(255, 255, 255, 0.3);
                width: 2.6rem;
                height: 2.6rem;
                border-radius: 999px;
                font-size: 1.15rem;
                color: white;
                background: rgba(0, 0, 0, 0.35);
                cursor: pointer;
                z-index: 20;
                transition: background-color 0.2s ease, transform 0.2s ease;
                &:hover {
                    background: rgba(255, 255, 255, 0.12);
                    transform: scale(1.05);
                }
            }
            &::before {
                content: "";
                z-index: -10;
                position: absolute;
                top: 0;
                right: 0;
                bottom: 0;
                left: 0;
                opacity: 0.9;
                background: linear-gradient(125deg, rgba(73, 183, 255, 0.24) 0%, rgba(255, 170, 88, 0.24) 100%);
                transform: scale(1.012);
                filter: blur(26px);
                transition: opacity 0.3s;
                border-radius: inherit;
            }
            @media (max-width: 600px) {
                width: calc(100% - 1.3rem);
                height: calc(100% - 1.3rem);
                min-height: unset;
                border-radius: 1.25rem;
                padding: 1rem 0.8rem 1rem;
                gap: 0.75rem;
                & > .closeIcon {
                    width: 2.2rem;
                    height: 2.2rem;
                    top: 0.7rem;
                    right: 0.7rem;
                }
            }
        }
        &::backdrop {
            background:
                radial-gradient(circle at 10% 20%, rgba(69, 166, 255, 0.18), transparent 40%),
                radial-gradient(circle at 85% 80%, rgba(255, 150, 73, 0.16), transparent 40%),
                rgba(1, 5, 10, 0.74);
            -webkit-backdrop-filter: blur(10px) saturate(130%);
            backdrop-filter: blur(10px) saturate(130%);
            animation: backdropAppear 0.3s;
        }
    }
    dialog.closing::backdrop {
        animation: backdropDisappear 0.3s;
    }
    dialog[open] {
        animation: transformIn 0.3s;
    }
    body:has(dialog[open]) {
        overflow: hidden;
        margin-right: 10px;
    }
    .dialog-buttons {
        display: flex;
        flex-direction: row;
        gap: 0.9rem;
        width: 100%;
        margin-top: 8vh;
        & > .link {
            font-size: clamp(1.1rem, 2vw, 1.5rem);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.45rem;
            border: 1px solid rgba(255, 255, 255, 0.15);
            border-radius: 0.95rem;
            background: linear-gradient(180deg, rgba(255, 255, 255, 0.14), rgba(255, 255, 255, 0.06));
            box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.2);
            transition: transform 0.2s ease, border-color 0.2s ease, background-color 0.2s ease;
            &:hover {
                transform: translateY(-2px);
                border-color: rgba(124, 214, 255, 0.5);
                background: linear-gradient(180deg, rgba(68, 183, 255, 0.3), rgba(255, 160, 91, 0.2));
            }
        }
        @media (max-width: 600px) {
            gap: 0.5rem;
            flex-direction: column;
            width: 96%;
        }
    }
    .dialog-copy {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
        width: 100%;
        padding-bottom: 0.15rem;
        & > p {
            max-width: 90%;
        }
    }
    .next-button, .prev-button {
        -webkit-user-select: none;
        user-select: none;
        position: absolute;
        border-radius: 100rem;
        font-size: x-large;
        color: white;
        text-decoration: none;
        text-align: center;
        width: 52px;
        height: 52px;
        padding: 0;
        cursor: pointer;
        border: 1px solid rgba(255, 255, 255, 0.25);
        background-color: rgba(13, 19, 28, 0.7);
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.35);
        -webkit-backdrop-filter: blur(8px) saturate(120%);
        backdrop-filter: blur(8px) saturate(120%);
        z-index: 10;
        transition: transform 0.2s ease, background-color 0.2s ease;
        &:hover {
            transform: scale(1.06);
            background-color: rgba(48, 137, 191, 0.5);
        }
        & > img {
            padding: 14px;
        }
        @media (max-width: 600px) {
            font-size: x-large;
            width: 42%;
            bottom: 0;
        }
    }
    .next-button {
        display: none;
        right: 1vw;
        & > img {
            transform: rotate(180deg);
        }
    }
    .prev-button {
        display: none;
        left: 1vw;
    }
    p {
        font-size: 26px;
        color: white;
        text-align: center;
        margin: 0;
        @media (max-width: 600px) {
            font-size: 20px;
        }
        @media (min-width: 1000px) and (max-width: 1920px) {
            font-size: 22px;
        }
    }
    .inset {
        width: 100%;
        height: 100%;
        box-shadow: 0 0 12px 6px rgba(0, 0, 0, 0.5);
        background: linear-gradient(0deg, rgba(0, 0, 0, 0.5), transparent);
        position: relative;
        border-radius: 1rem;
        overflow: hidden;
        & > img {
            position: relative;
            width: inherit;
            height: inherit;
            object-fit: cover;
            border-radius: 1rem;
            filter: blur(1px);
            clip-path: border-box;
            z-index: -1;
        }
    }
    span {
        display: flex;
        align-items: end;
        justify-content: space-between;
        position: absolute;
        width: -webkit-fill-available;
        width: -moz-available;
        bottom: 1rem;
        margin: 0 1rem;
        & > p:first-of-type {
            text-align: left;
        }
        & > p:last-of-type {
            text-align: right;
        }
        & > p {
            font-family: "FugazOne",serif;
            line-height: 1;
        }
    }

