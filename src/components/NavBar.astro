---
const links = [
	{ href: "#home", text: "Home" },
	{ href: "#projects", text: "Projects" },
	{ href: "#contact", text: "Contact" },
];
---

<script>
	let activeSection = "home";
	const sections = document.querySelectorAll("nav a");
	// let isScrolling = false;

	const getOffsetTop = (selector: string) => {
		const el = document.querySelector(selector);
		return el instanceof HTMLElement ? el.offsetTop : 0;
	};
	const getOffsetBottom = (selector: string) => {
		const el = document.querySelector(selector);
		return el instanceof HTMLElement ? el.offsetTop + el.offsetHeight : 0;
	};

	const getPageTop = (selector: string) => {
		const el = document.querySelector(selector);
		return el instanceof HTMLElement ? el.getBoundingClientRect().top + window.scrollY : null;
	};

	const scrollToSection = (selector: string) => {
		const sectionTop = getPageTop(selector);
		if (sectionTop === null) return;

		const extraOffset = selector === "#projects" ? (window.innerWidth < 1000 ? window.innerWidth / 2 + 300 : window.innerWidth / 2) : 0;
		window.scrollTo({
			top: sectionTop + extraOffset,
			behavior: "smooth",
		});
	};

	// move .highlight to the clicked link and on scroll to the section in view
	function moveHighlight() {
		// isScrolling = true;
		const activeLink = document.querySelector(
			`nav a[href="#${activeSection}"]`,
		);
		const highlight = document.querySelector(".highlight") as HTMLElement;
		if (activeLink && highlight) {
			const { offsetLeft, offsetWidth } = activeLink as HTMLElement;
			highlight.style.transform = `translateX(${offsetLeft}px)`;
			highlight.style.width = `${offsetWidth}px`;
		}
		// setTimeout(() => {
		// 	isScrolling = false;
		// }, 1500);
	}

	// move highlight to hovered link
	sections.forEach((link) => {
		link.addEventListener("mouseenter", () => {
			const { offsetLeft, offsetWidth } = link as HTMLElement;
			const highlight = document.querySelector(".highlight") as HTMLElement;
			if (highlight) {
				highlight.style.transform = `translateX(${offsetLeft}px)`;
				highlight.style.width = `${offsetWidth}px`;
			}
		});
		link.addEventListener("mouseleave", () => {
			moveHighlight();
		});
	});

	// move highlight on scroll to the section in view
	window.addEventListener("scroll", () => {
		// if (isScrolling) return;
		const scrollPosition = window.scrollY + window.innerHeight / 2;

		const projectsTop = getOffsetTop("#projects");
		const projectsBottom = getOffsetBottom("#projects");

		if (scrollPosition >= projectsBottom) {
			activeSection = "contact";
		} else if (scrollPosition >= projectsTop) {
			activeSection = "projects";
		} else {
			activeSection = "home";
		}

		moveHighlight();
	});

	// move highlight on click
	sections.forEach((link) => {
		link.addEventListener("click", (event) => {
			const href = link.getAttribute("href");
			if (!href || !href.startsWith("#")) return;

			event.preventDefault();
			activeSection = href.substring(1);
			moveHighlight();
			scrollToSection(href);
		});
	});
	// initial highlight position
	moveHighlight();
</script>

<nav>
	<div class="nav-inner">
		<div class="highlight"></div>
		{links.map((link) => <a href={link.href}>{link.text}</a>)}
	</div>
</nav>

<style>
	nav {
		top: 3vh;
		position: fixed;
		background-color: rgba(20, 20, 20, 0.5);
		border-radius: 90pt;
		padding: 0.5rem;
		-webkit-backdrop-filter: blur(7px);
		backdrop-filter: blur(7px);
		z-index: 100;
		box-shadow: inset 0 0 15px 0 rgba(53, 53, 53, 0.5);
		@media (max-width: 600px) {
			width: 90%;
		}
		@media (max-width: 1200px) {
			width: 80vw;
		}
		@media (min-width: 1000px) and (max-width: 1920px) {
			width: clamp(420px, 38vw, 700px);
			top: 4vh;
			padding: 0.25rem 0.5rem;
		}
	}
	div {
		display: flex;
		justify-content: space-around;
		align-items: center;
	}
	a {
		color: rgb(216, 216, 216);
		text-decoration: none;
		padding: 0.7rem 1.2rem;
		position: relative;
		@media (min-width: 1000px) and (max-width: 1920px) {
			font-size: 28px;
		}
	}
	.nav-inner {
		position: relative;
		display: flex;
	}

	nav a {
		position: relative;
		z-index: 1;
		transition:
			color 0.25s ease,
			transform 0.2s ease;
	}

	nav a.active {
		color: white;
	}
	.nav-inner {
	}
	.highlight {
		position: absolute;
		left: 0;
		top: 0;
		height: 100%;
		will-change: transform, width;
		border-radius: 999px;

		background: rgba(255, 255, 255, 0.08);

		backdrop-filter: blur(18px) saturate(180%);
		-webkit-backdrop-filter: blur(18px) saturate(180%);

		/* background-image: linear-gradient(
		135deg,
		rgba(0, 255, 140, 0.18),
		rgba(0, 200, 255, 0.12)
	); */
		transition: all 0.3s ease;

		border: 1px solid rgba(255, 255, 255, 0.18);

		box-shadow:
			0 10px 30px rgba(0, 0, 0, 0.25),
			inset 0 1px 1px rgba(255, 255, 255, 0.35),
			inset 0 -6px 12px rgba(0, 0, 0, 0.15);

		position: absolute;
		overflow: hidden;
	}

	.highlight::before {
		position: absolute;
		content: "";
		bottom: -60%;
		left: 20%;
		height: 70%;
		border-radius: 100%;
		width: 60%;
		background-color: rgba(255, 255, 255, 0.4);
		filter: blur(10px);
	}
</style>
